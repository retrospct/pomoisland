{
  "name": "pomoisland",
  "version": "0.1.0",
  "description": "Dynamic Island Pomodoro — a macOS notch-aware focus timer",
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11"
  },
  "main": "out/main/main.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "audio:check": "node scripts/audio-check.ts",
    "tick:check": "node scripts/tick-cadence-check.ts",
    "placement:check": "node scripts/placement-check.ts",
    "package": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir",
    "dist:mac": "electron-vite build && node scripts/run-with-env.mjs electron-builder --mac"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "6.0.0-beta.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "node-web-audio-api": "^2.0.0",
    "prettier": "^3.9.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  }
}